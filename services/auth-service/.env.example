# ============================================
# Auth Service - Environment Variables
# ============================================
# Copy this file to .env for local development (without Docker)
# When using Docker Compose, env vars are set in docker-compose.yml

PORT=3000
NODE_ENV=development

# Database (Local PostgreSQL example)
DATABASE_URL=
DIRECT_URL=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google OAuth
GOOGLE_CLIENT_ID=
