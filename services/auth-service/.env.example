# ============================================
# Auth Service - Environment Variables
# ============================================
# Copy this file to .env for local development (without Docker)
# When using Docker Compose, env vars are set in docker-compose.yml

PORT=3000
NODE_ENV=development

# Database (Local PostgreSQL example)
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/auth_db?schema=public
DIRECT_URL=postgresql://postgres:postgres_password@localhost:5432/auth_db?schema=public

# Supabase example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
