# ============================================
# Template Service - Environment Variables
# ============================================
# Copy this file to .env for local development (without Docker)
# When using Docker Compose, env vars are set in docker-compose.yml

PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=auth_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
