{
  "info": {
    "_postman_id": "capstone-bidding-qa-testing",
    "name": "Bidding Capstone - Auth Service Testing",
    "description": "Test Collection untuk Auth Service - Platform Bidding Capstone Projects\n\n**Role dalam Sistem:**\n- Mahasiswa: Pencari proyek capstone (contoh: rifqi@mahasiswa.ac.id)\n- Mitra: Pemberi proyek capstone (contoh: contact@ptdigital.com)\n- Admin: Administrator sistem\n\n**Flow Testing:**\n1. Register mahasiswa baru\n2. Register mitra baru\n3. Login dan simpan token\n4. Lihat profil user\n5. Update profil (nama/password)\n6. Logout\n\n**Total Tests: 19 test cases**\n- Semua test harus pass (status 200, 201, atau error yang diharapkan)\n- Token otomatis disimpan di environment setelah login\n- Gunakan token untuk protected endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "Cek Status Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status harus 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Service berjalan dengan baik', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success', true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/health",
              "host": ["{{BASE_URL}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Registrasi",
      "item": [
        {
          "name": "Register Mahasiswa - Valid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response berhasil', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data.user.role).to.equal('mahasiswa');",
                  "    pm.environment.set('mahasiswa_email', jsonData.data.user.email);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Achmad Rifqi\",\n  \"email\": \"rifqi{{$timestamp}}@mahasiswa.ac.id\",\n  \"password\": \"RifqiPass@123\",\n  \"role\": \"mahasiswa\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Mitra - Valid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response berhasil', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data.user.role).to.equal('mitra');",
                  "    pm.environment.set('mitra_email', jsonData.data.user.email);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"PT Digital Indonesia\",\n  \"email\": \"hrd{{$timestamp}}@ptdigital.com\",\n  \"password\": \"PTDigital@2026\",\n  \"role\": \"mitra\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register - Nama Kosong (Error 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', function () {", "    pm.response.to.have.status(400);", "});", "", "pm.test('Error message muncul', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password@123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Register - Email Format Salah (Error 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', function () {", "    pm.response.to.have.status(400);", "});", "", "pm.test('Reject email format buruk', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"email-invalid\",\n  \"password\": \"Password@123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Register - Password Terlalu Pendek (Error 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', function () {", "    pm.response.to.have.status(400);", "});", "", "pm.test('Reject password pendek', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Register - Email Sudah Terdaftar (Error 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 409 Conflict', function () {", "    pm.response.to.have.status(409);", "});", "", "pm.test('Email duplicate error', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Admin Existing\",\n  \"email\": \"admin@capstone.test\",\n  \"password\": \"AdminPass@123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/register", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "register"]}
          }
        }
      ]
    },
    {
      "name": "3. Login",
      "item": [
        {
          "name": "Login Mahasiswa - Valid (Simpan Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token berhasil didapat', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('accessToken');",
                  "    pm.expect(jsonData.data).to.have.property('refreshToken');",
                  "    pm.environment.set('accessToken', jsonData.data.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.data.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{mahasiswa_email}}\",\n  \"password\": \"RifqiPass@123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "Login - Password Salah (Error 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', function () {", "    pm.response.to.have.status(401);", "});", "", "pm.test('Reject password salah', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"{{mahasiswa_email}}\",\n  \"password\": \"WrongPassword123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "Login - Email Tidak Terdaftar (Error 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', function () {", "    pm.response.to.have.status(401);", "});", "", "pm.test('Reject user tidak ada', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"notfound@mahasiswa.ac.id\",\n  \"password\": \"Password@123\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/login", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "login"]}
          }
        }
      ]
    },
    {
      "name": "4. Token Management",
      "item": [
        {
          "name": "Refresh Token - Dapatkan Access Token Baru",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Access token baru didapat', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('accessToken');",
                  "    pm.environment.set('accessToken', jsonData.data.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/refresh", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "refresh"]}
          }
        }
      ]
    },
    {
      "name": "5. Logout",
      "item": [
        {
          "name": "Logout - Valid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Logout berhasil', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/logout", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "logout"]}
          }
        },
        {
          "name": "Logout - Tanpa Token (Error 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', function () {", "    pm.response.to.have.status(401);", "});", "", "pm.test('Reject no token', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/logout", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "logout"]}
          }
        }
      ]
    },
    {
      "name": "6. Profile",
      "item": [
        {
          "name": "Lihat Profile - Valid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Profile data lengkap', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data.user).to.have.property('id');",
                  "    pm.expect(jsonData.data.user).to.have.property('email');",
                  "    pm.expect(jsonData.data.user).to.have.property('name');",
                  "    pm.expect(jsonData.data.user).to.have.property('role');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "url": {"raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"]}
          }
        },
        {
          "name": "Lihat Profile - Tanpa Token (Error 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', function () {", "    pm.response.to.have.status(401);", "});", "", "pm.test('Reject no token', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"]}
          }
        },
        {
          "name": "Lihat Profile - Token Invalid (Error 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', function () {", "    pm.response.to.have.status(401);", "});", "", "pm.test('Reject invalid token', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer invalid-token-123"}],
            "url": {"raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"]}
          }
        },
        {
          "name": "Update Profile - Ubah Nama",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Nama berhasil diupdate', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data.user.name).to.equal('Rifqi Ahmad Pratama');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Rifqi Ahmad Pratama\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"]}
          }
        },
        {
          "name": "Update Profile - Ubah Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Password berhasil diubah', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"password\": \"NewPassword@2026\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"]}
          }
        },
        {
          "name": "Update Profile - Tanpa Token (Error 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', function () {", "    pm.response.to.have.status(401);", "});", "", "pm.test('Reject no token', function () {", "    var jsonData = pm.response.json();", "    pm.expect(jsonData.success).to.be.false;", "});"]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"New Name\"\n}"},
            "url": {"raw": "{{BASE_URL}}/api/auth/profile", "host": ["{{BASE_URL}}"], "path": ["api", "auth", "profile"]}
          }
        }
      ]
    }
  ]
}
