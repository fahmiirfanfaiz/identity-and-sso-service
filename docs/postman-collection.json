{
  "info": {
    "name": "Identity & SSO - API Collection",
    "description": "Postman collection untuk testing endpoint Identity & SSO Service berdasarkan docs/swagger.yml.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"{{role}}\"\n}"
            },
            "description": "Mendaftarkan user baru untuk testing lokal."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = (() => { try { return pm.response.json(); } catch(e) { return null; } })();",
                  "pm.test('Response status is 201', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "if (json && json.data && json.data.user && json.data.user.id) {",
                  "  pm.environment.set('userId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "description": "Login user dan simpan accessToken / refreshToken ke environment."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = (() => { try { return pm.response.json(); } catch(e) { return null; } })();",
                  "pm.test('Response status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "if (json && json.data) {",
                  "  const access = json.data.accessToken || '';",
                  "  const refresh = json.data.refreshToken || '';",
                  "  const uid = json.data.user && json.data.user.id ? json.data.user.id : '';",
                  "  if (access) pm.environment.set('accessToken', access);",
                  "  if (refresh) pm.environment.set('refreshToken', refresh);",
                  "  if (uid) pm.environment.set('userId', uid);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\"\n}"
            },
            "description": "Login menggunakan Google ID token."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = (() => { try { return pm.response.json(); } catch(e) { return null; } })();",
                  "pm.test('Response status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "if (json && json.data) {",
                  "  const access = json.data.accessToken || '';",
                  "  const refresh = json.data.refreshToken || '';",
                  "  const uid = json.data.user && json.data.user.id ? json.data.user.id : '';",
                  "  if (access) pm.environment.set('accessToken', access);",
                  "  if (refresh) pm.environment.set('refreshToken', refresh);",
                  "  if (uid) pm.environment.set('userId', uid);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Tukar refresh token menjadi access token baru."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = (() => { try { return pm.response.json(); } catch(e) { return null; } })();",
                  "pm.test('Response status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "if (json && json.data && json.data.accessToken) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Logout user dan hapus refresh token."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('refreshToken');",
                  "pm.test('Logout response status is 200', function () { pm.expect(pm.response.code).to.eql(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Administration",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "description": "Login admin dan simpan token admin ke environment."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = (() => { try { return pm.response.json(); } catch(e) { return null; } })();",
                  "pm.test('Response status is 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "if (json && json.data) {",
                  "  const access = json.data.accessToken || '';",
                  "  const refresh = json.data.refreshToken || '';",
                  "  const uid = json.data.user && json.data.user.id ? json.data.user.id : '';",
                  "  if (access) pm.environment.set('adminAccessToken', access);",
                  "  if (refresh) pm.environment.set('adminRefreshToken', refresh);",
                  "  if (uid) pm.environment.set('adminUserId', uid);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/admin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", "admin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"admin\"\n}"
            },
            "description": "Registrasi admin baru via admin access token."
          },
          "response": []
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/users/{{targetUserId}}/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "users", "{{targetUserId}}", "deactivate"]
            },
            "description": "Menonaktifkan user lain dari akun admin."
          },
          "response": []
        }
      ]
    },
